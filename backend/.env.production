# ============================================================
# Backend Production Environment Variables
# Copy this to .env and fill in real values before deploying
# ============================================================

ENV=production

# --- Security (REQUIRED — app refuses to start without these) ---
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_SECRET_KEY=CHANGE_ME_TO_A_DIFFERENT_RANDOM_64_CHAR_STRING
JWT_COOKIE_CSRF_PROTECT=true

# --- Database ---
MONGO_URI=mongodb://localhost:27017/intelligent_edu

# --- CORS (comma-separated production origins) ---
ALLOWED_ORIGINS=https://your-domain.com

# --- Gmail OAuth ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://your-domain.com/gmail/callback

# --- AI API Keys ---
DEEPSEEK_API_KEY=
COZE_TOKEN=
COZE_BOT_ID=
ZHIPU_API_KEY=

# --- Optional ---
LOG_LEVEL=WARNING
JWT_EXPIRES_HOURS=24
COZE_REQUEST_TIMEOUT_SECONDS=90
