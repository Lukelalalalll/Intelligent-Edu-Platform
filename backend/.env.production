# ============================================================
# Backend Production Environment Variables
# Example template only. Do not commit live secrets.
# Copy this to a private deploy-time env file and fill in real values.
# ============================================================

ENV=production

# --- Security ---
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_SECRET_KEY=CHANGE_ME_TO_A_DIFFERENT_RANDOM_64_CHAR_STRING
INTERNAL_GATEWAY_TOKEN=CHANGE_ME_TO_A_THIRD_RANDOM_64_CHAR_STRING
JWT_COOKIE_SECURE=true
JWT_COOKIE_CSRF_PROTECT=true
JWT_COOKIE_SAMESITE=none
ADMIN_DB_CONSOLE_ENABLED=false

# --- Database ---
MONGO_URI=mongodb://USERNAME:PASSWORD@YOUR-MONGO-HOST:27017/intelligent_edu
SEARXNG_BASE_URL=http://searxng:8080

# --- CORS (comma-separated frontend origins) ---
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,https://your-custom-domain.example

# --- Google OAuth ---
GOOGLE_AUTH_CLIENT_ID=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://your-custom-domain.example/gmail/callback

# --- AI API Keys ---
DEEPSEEK_API_KEY=
COZE_TOKEN=
COZE_BOT_ID=
ZHIPU_API_KEY=
SERPAPI_KEY=
HDGSB_API_KEY=

# --- Optional ---
LOG_LEVEL=WARNING
JWT_EXPIRES_HOURS=24
COZE_REQUEST_TIMEOUT_SECONDS=90
SEARXNG_FETCH_CONTENT=false
