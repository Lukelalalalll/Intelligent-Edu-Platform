ENV=production
MONGO_URI=mongodb://mongo:27017/intelligent_edu
SEARXNG_BASE_URL=http://searxng:8080
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_SECRET_KEY=CHANGE_ME_TO_A_DIFFERENT_RANDOM_64_CHAR_STRING
JWT_COOKIE_SECURE=true
JWT_COOKIE_CSRF_PROTECT=true
JWT_COOKIE_SAMESITE=lax
ALLOWED_ORIGINS=https://your-domain.com
INTERNAL_GATEWAY_TOKEN=CHANGE_ME_TO_A_RANDOM_INTERNAL_GATEWAY_TOKEN
LOG_LEVEL=INFO
# Local dev note: use the same INTERNAL_GATEWAY_TOKEN value in frontend/.env.local
# so Vite can inject X-Internal-Gateway while proxying /api requests.
