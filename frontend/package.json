{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "lint:css": "stylelint \"src/styles/**/*.css\"",
    "lint:css:fix": "stylelint \"src/styles/**/*.css\" --fix",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "openapi:fetch": "node scripts/fetch-openapi.mjs",
    "openapi:gen": "openapi-typescript src/types/openapi.json -o src/types/generated/schema.d.ts",
    "openapi:sync": "npm run openapi:fetch && npm run openapi:gen"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3",
    "@tanstack/react-virtual": "^3.13.23",
    "axios": "^1.13.6",
    "dompurify": "^3.3.3",
    "framer-motion": "^12.38.0",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "liquid-glass-react": "^1.1.1",
    "marked": "^17.0.4",
    "pdfjs-dist": "^4.8.69",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^9.2.1",
    "react-pdf-highlighter": "^6.1.0",
    "react-router-dom": "^7.13.1",
    "react-syntax-highlighter": "^16.1.1",
    "sonner": "^2.0.7",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.75",
    "@types/react-dom": "^18.2.25",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^6.7.6",
    "stylelint": "^16.25.0",
    "stylelint-config-idiomatic-order": "^10.0.0",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-order": "^8.1.1",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vitest": "^2.1.9"
  }
