# In local Vite dev, keep API requests same-origin so the dev proxy can inject
# X-Internal-Gateway before forwarding to the backend.
VITE_API_ROOT=/
# Optional local dev override for the Vite /api proxy target.
# Local backend runs on 5009 via ../run-backend.cmd.
VITE_DEV_BACKEND_TARGET=http://localhost:5009
VITE_GOOGLE_AUTH_CLIENT_ID=

# Local dev only: Vite injects this header when proxying /api to the backend.
# Set the same value in backend/.env as INTERNAL_GATEWAY_TOKEN.
INTERNAL_GATEWAY_TOKEN=dev-internal-gateway-token-change-me
