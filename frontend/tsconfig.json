{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting — relaxed for migration, will tighten later */
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "useUnknownInCatchVariables": false,
    "forceConsistentCasingInFileNames": true,
    "types": ["jest", "vitest/globals"],

    /* Allow JS/TS coexistence during migration */
    "allowJs": true,
    "checkJs": false,

    /* JSON imports (shared data/slide_themes.json) */
    "resolveJsonModule": true,

    /* Path resolution */
    "paths": {
      "@/*": ["./src/*"],
      "next": ["./src/presenton/shims/next.ts"],
      "next/navigation": ["./src/presenton/shims/next-navigation.ts"],
      "next/link": ["./src/presenton/shims/next-link.tsx"],
      "next/image": ["./src/presenton/shims/next-image.tsx"],
      "next/headers": ["./src/presenton/shims/next-headers.ts"]
    }
  },
  "include": ["src"]
}
