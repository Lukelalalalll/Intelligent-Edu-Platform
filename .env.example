# Backend
# OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2-vision:11b
COZE_API_KEY=your-coze-api-key
COZE_BOT_ID=your-coze-bot-id
COZE_API_URL=https://api.coze.com/v1/chat
# DeepSeek API (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
# SerpAPI for diagram search fallback (https://serpapi.com/)
SERP_API_KEY=your-serp-api-key

# Optional: OpenSearch for enterprise RAG sparse + metadata retrieval
RAG_OPENSEARCH_ENABLED=false
RAG_OPENSEARCH_ENDPOINT=http://127.0.0.1:9200
RAG_OPENSEARCH_INDEX_PREFIX=course-rag
RAG_OPENSEARCH_TIMEOUT_SECONDS=5
RAG_OPENSEARCH_VERIFY_CERTS=false
# RAG_OPENSEARCH_USERNAME=
# RAG_OPENSEARCH_PASSWORD=
# RAG_OPENSEARCH_CA_CERTS=

GMAIL_CLIENT_ID=your-google-oauth-client-id
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_PROJECT_ID=intelligent-edu-platform
GMAIL_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GMAIL_TOKEN_URI=https://oauth2.googleapis.com/token
GMAIL_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GMAIL_REDIRECT_URI=http://localhost:5173/gmail/callback
GOOGLE_AUTH_CLIENT_ID=your-google-identity-client-id

# Frontend
VITE_API_ROOT=http://localhost:5009
VITE_GOOGLE_AUTH_CLIENT_ID=your-google-identity-client-id
