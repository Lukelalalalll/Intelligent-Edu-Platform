# Copy this file to a secure path outside the repository and pass it to:
# docker compose --env-file /secure/path/compose.prod.env up --build -d

# Required container-to-container gateway secret.
INTERNAL_GATEWAY_TOKEN=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# Required SearXNG application secret.
SEARXNG_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# Required backend application secrets.
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_SECRET_KEY=CHANGE_ME_TO_A_DIFFERENT_RANDOM_64_CHAR_STRING

# Required production CORS origins, comma-separated.
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app

# Required when the Vercel frontend and Docker backend are on different sites.
# Keep JWT_COOKIE_SECURE=true in docker-compose.yml.
JWT_COOKIE_SAMESITE=none

# Keep frontend requests same-origin behind edge-nginx.
VITE_API_ROOT=/
VITE_DISABLE_AUTH=false
VITE_MIXPANEL_TOKEN=

# Optional external providers. Leave empty to disable related features.
SERPAPI_KEY=
HDGSB_API_KEY=

# Production hardening defaults.
ADMIN_DB_CONSOLE_ENABLED=false
SEARXNG_FETCH_CONTENT=false

# Optional per-service overrides.
# CORE_GUNICORN_WORKERS=2
# SLIDES_GUNICORN_WORKERS=1
# VIDEO_GUNICORN_TIMEOUT=600
